          "ruleset" : "$ruleset"
        }
      },
      {
        "type" : "nav",
        "text" : "Multiplayer ▸",
        "screen" : "mp"
      }
    ]
  },
  {
    "id" : "mp",
    "title" : "Multiplayer",
    "components" : [
      {
        "type" : "button",
        "text" : "Create Lobby",
        "intent" : "createLobby",
        "params" : { }
      },
      {
        "type" : "stat",
        "label" : "Lobby code",
        "source" : "lobbyCode"
      },
      {
        "type" : "input",
        "id" : "code",
